# ============================================
# Git 忽略文件配置
# ============================================

# ---------- 敏感文件（最重要！）----------
.env
.env.*
*.env
!.env.example

# Token 缓存（包含认证信息）
.token_cache.bin

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ---------- 虚拟环境 ----------
venv/
.venv/
env/
ENV/

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- macOS ----------
.DS_Store
.AppleDouble
.LSOverride

# ---------- 日志和临时文件 ----------
*.log
*.tmp
*.temp


# ---------- Runtime outputs ------------
output/
Output/
Stage_1/

# ---------- Personal notes ----------
Learning_Note.md

# Keep documentation and dependency manifests trackable.
!README.md
!requirements.txt
